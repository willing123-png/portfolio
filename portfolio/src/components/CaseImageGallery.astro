---
const {
  projectNo,
  title,
  subtitle = "",
  description = "",
  tags = [],
  images = [],
  backHref = "/#projects",
  backLabel = "返回作品集",
} = Astro.props;

const defaultImageSizes = "(min-width: 768px) min(1172px, calc(100vw - 128px)), calc(100vw - 24px)";
const assetVersion = "20260702-youware-refresh";

const versionAsset = (url) => {
  if (!url) return url;

  const [baseUrl, hash] = url.split("#");
  const separator = baseUrl.includes("?") ? "&" : "?";
  return `${baseUrl}${separator}v=${assetVersion}${hash ? `#${hash}` : ""}`;
};

const versionSrcset = (srcset = "") =>
  srcset
    .split(",")
    .map((entry) => {
      const trimmedEntry = entry.trim();
      if (!trimmedEntry) return trimmedEntry;

      const [url, ...descriptor] = trimmedEntry.split(/\s+/);
      return [versionAsset(url), ...descriptor].join(" ");
    })
    .join(", ");

const imageList = images.map((image, index) => {
  const imageData = typeof image === "string" ? { src: image } : image;
  const number = String(index + 1).padStart(2, "0");

  return {
    ...imageData,
    src: versionAsset(imageData.src),
    alt: imageData.alt ?? `${title} 案例图 ${number}`,
    sizes: imageData.sizes ?? defaultImageSizes,
    sources: (imageData.sources ?? []).map((source) => ({
      ...source,
      srcset: versionSrcset(source.srcset),
    })),
  };
});
---

<main class="min-h-screen w-full bg-[var(--color-ink)] text-[17px] leading-relaxed">
  <header class="w-full max-w-none px-3 pb-8 pt-6 md:mx-auto md:max-w-[1300px] md:px-16 md:pb-12 md:pt-10">
    <a href={backHref} class="text-sm text-[var(--color-accent)] transition-colors hover:text-white">
      ← {backLabel}
    </a>

    <div class="mt-12 max-w-3xl md:mt-16">
      <p class="text-sm tracking-[0.3em] text-[var(--color-muted)]">{projectNo}</p>
      <h1
        style="font-family:var(--font-display)"
        class="mt-4 text-4xl font-black leading-tight md:text-6xl"
      >
        {title}
      </h1>
      {subtitle && <p class="mt-4 text-lg text-[var(--color-muted)] md:text-xl">{subtitle}</p>}
      {description && <p class="mt-5 max-w-2xl text-[var(--color-muted)]">{description}</p>}

      {tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="rounded-full border border-white/15 px-3 py-1 text-xs text-[var(--color-muted)]">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </header>

  <section class="mx-auto flex w-full max-w-none flex-col gap-3 px-3 pb-16 md:max-w-[1300px] md:gap-8 md:px-16 md:pb-24">
    {imageList.map((image, index) => {
      const isFirstImage = index === 0;

      return (
        <picture class="block w-full">
          {image.sources.map((source) => (
            <source type={source.type} srcset={source.srcset} sizes={image.sizes} />
          ))}
          <img
            src={image.src}
            alt={image.alt}
            width={image.width}
            height={image.height}
            loading={isFirstImage ? "eager" : "lazy"}
            fetchpriority={isFirstImage ? "high" : undefined}
            decoding="async"
            class="block h-auto w-full"
          />
        </picture>
      );
    })}
  </section>
</main>
