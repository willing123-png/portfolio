---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articles } from '../../data/articles.js';

export function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.slug }, props: { a } }));
}

const { a } = Astro.props;
---

<BaseLayout title={`${a.title} · 吴悠`} description={a.excerpt}>
  <main class="w-full">
    <article class="mx-auto w-full max-w-[760px] px-6 py-16 md:py-24">
      <a href="/#article" class="text-sm text-[var(--color-accent)]">← 返回作品集</a>

      <h1 style="font-family:var(--font-sans)" class="mt-8 text-3xl font-bold leading-snug md:text-4xl">{a.title}</h1>
      <p class="mt-3 text-sm text-[var(--color-muted)]">{a.tag} · {a.read}</p>

      <div class="mt-10 space-y-6 text-[17px] leading-[1.9] text-white/85">
        {a.body.map((p) => <p>{p}</p>)}
      </div>

      {a.links && (
        <div class="mt-12 border-t border-white/10 pt-6">
          <p class="text-sm font-semibold text-[var(--color-muted)]">推荐教程</p>
          <ul class="mt-3 space-y-2">
            {a.links.map((l) => (
              <li>
                <a href={l.url} target="_blank" rel="noopener" class="text-[var(--color-accent)] hover:underline">{l.label} ↗</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="mt-14 border-t border-white/10 pt-6">
        <a href="/#article" class="text-sm text-[var(--color-accent)]">← 返回作品集</a>
      </div>
    </article>
  </main>
</BaseLayout>
