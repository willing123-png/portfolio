---
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseImageGallery from '../components/CaseImageGallery.astro';

const images = Array.from(
  { length: 11 },
  (_, index) => `/assets/projects/hapi/${String(index + 1).padStart(2, "0")}.png`
);
---
<BaseLayout title="哈皮 · 核心体验优化 · 吴悠">
  <CaseImageGallery
    projectNo="PROJECT 03"
    title="哈皮 · 核心体验优化"
    subtitle="腾讯 PCG 实习"
    tags={["全流程设计"]}
    images={images}
  />
</BaseLayout>
