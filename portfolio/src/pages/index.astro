---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articles } from '../data/articles.js';

const internships = [
  {
    company: "腾讯公司 PCG 平台与内容事业群",
    period: "2025.09 - 2025.12",
    desc: "工作内容：1. 主要参与 0-1 阶段 ToC 产品「哈皮」微信小游戏平台体验全流程设计，围绕商业目标（提升 DAU）主动挖掘需求，从业务诉求和用户定位出发，明确当前的设计机会点，进行相应的交互设计、UI 设计。共负责了 8 个需求，2 个 A 级需求，5 个 B 级需求，1 个 C 级需求。",
  },
  {
    company: "桥介数物（深圳）科技有限公司",
    period: "2025.03 - 2025.07",
    desc: "工作内容：1. 负责 0-1「桥介引擎」PC 端机器人动作开发平台，功能流程设计和高保真视觉设计。梳理基础设计规范以及常用基础模块的组件整理。",
  },
];

const projects = [
  { no: "01", title: "AI 编程工具", sub: "创建项目体验优化", org: "Youware 自发项目", tags: ["多方案设计", "设计自驱"], href: "/youware" },
  { no: "02", title: "马蜂窝", sub: "营销活动设计", org: "校企合作项目", tags: ["创意视觉", "AIGC应用"], href: "/mafengwo" },
  { no: "03", title: "哈皮", sub: "核心体验优化", org: "腾讯 PCG 实习", tags: ["全流程设计"], href: "/hapi" },
  { no: "04", title: "AI 看展", sub: "0-1 项目", org: "抖音黑客松探索尝试", tags: ["设计创新"], href: "/exhibition" },
];

const wrap = "mx-auto w-full max-w-[1300px] px-6 md:px-16";
---

<BaseLayout title="吴悠 · UI/UX 作品集">
  <main class="w-full text-[17px] leading-relaxed">

    <!-- ============ 封面（整屏铺满） ============ -->
    <section class="relative min-h-[92svh] w-full overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/30 to-[var(--color-ink)]"></div>

      <div class={`relative z-10 flex min-h-[92svh] flex-col justify-between py-8 md:py-14 ${wrap}`}>
        <div></div>

        <!-- 主标题 -->
        <div class="mt-auto">
          <div class="flex items-end gap-5">
            <h1 style="font-family:var(--font-display); font-size:clamp(52px,13vw,200px)" class="font-black leading-[0.82] tracking-tight">
              PORTFOLIO
            </h1>
            <span class="mb-3 hidden h-16 w-16 shrink-0 items-center justify-center rounded-full border-2 border-white/80 text-3xl md:flex">↗</span>
          </div>
          <h2 style="font-family:var(--font-display); font-size:clamp(40px,10vw,150px)" class="font-bold leading-none">WORK</h2>

          <div class="mt-10 space-y-1.5 text-base text-white/85 md:text-lg">
            <p class="text-xl font-medium md:text-2xl">吴悠</p>
            <p>Phone：+86 198 2230 6332</p>
            <p>Email：willinginworld@gmail.com</p>
            <p class="pt-2 tracking-[0.3em] text-white/70">UI &amp; UX DESIGNER</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 设计理念 + 实习经历 ============ -->
    <section class="w-full py-20 md:py-28">
      <div class={wrap}>
        <!-- Less but better -->
        <div class="flex flex-col gap-10 md:flex-row md:items-start md:gap-16">
          <img
            src="/assets/home/portrait.jpg"
            alt="吴悠证件照"
            class="aspect-[3/4] w-48 shrink-0 rounded-xl object-cover md:w-64"
          />
          <div class="flex-1">
            <p style="font-family:var(--font-display)" class="text-4xl font-medium italic text-[var(--color-accent)] md:text-6xl">
              Less but better
            </p>
            <p class="mt-2 text-base text-[var(--color-muted)]">—— 迪特·拉姆斯（Dieter Rams）</p>

            <div class="mt-10 grid gap-10 sm:grid-cols-2">
              <div>
                <p class="text-lg font-semibold text-[var(--color-accent)]">意义驱动设计</p>
                <p class="mt-3 leading-relaxed text-[var(--color-muted)]">
                  追求"真正有用"而非"仅仅好看"的设计，让设计能真正解决问题。
                </p>
              </div>
              <div>
                <p class="text-lg font-semibold text-[var(--color-accent)]">敏捷拥抱新技术</p>
                <p class="mt-3 leading-relaxed text-[var(--color-muted)]">
                  关注新技术、多次参加国内赛事，对于把新点子"落地成型"有着丰富的兴趣与经验。
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- 实习经历 -->
        <div class="mt-16">
          <h3 class="text-2xl font-semibold">实习经历</h3>
          <div class="mt-8 space-y-10">
            {internships.map((it) => (
              <div class="border-l-2 border-[var(--color-accent)]/50 pl-6">
                <div class="flex flex-wrap items-baseline justify-between gap-2">
                  <p class="text-lg font-medium">{it.company}</p>
                  <p class="text-sm text-[var(--color-muted)]">{it.period}</p>
                </div>
                <p class="mt-3 leading-relaxed text-[var(--color-muted)]">{it.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 项目索引（整屏深底） ============ -->
    <section id="projects" class="w-full bg-[var(--color-ink-2)] py-20 md:py-28">
      <div class={wrap}>
        <h2 style="font-family:var(--font-display); font-size:clamp(48px,8vw,120px)" class="font-black tracking-tight">PROJECT</h2>

        <div class="mt-12 grid gap-px overflow-hidden rounded-2xl border border-white/10 bg-white/10 sm:grid-cols-2 lg:grid-cols-4">
          {projects.map((p) => (
            <a href={p.href} class="group relative flex flex-col bg-[var(--color-ink-2)] p-8 transition-colors hover:bg-white/[0.04]">
              <span style="font-family:var(--font-display)" class="text-7xl font-black text-white/10 transition-colors group-hover:text-white/20">{p.no}</span>
              <p class="mt-5 text-xl font-semibold">{p.title}</p>
              <p class="text-[var(--color-muted)]">{p.sub}</p>
              <p class="mt-1 text-sm text-[var(--color-muted)]/70">{p.org}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {p.tags.map((t) => (
                  <span class="rounded-full border border-white/15 px-3 py-1 text-xs text-[var(--color-muted)]">{t}</span>
                ))}
              </div>
              <span class="mt-5 text-sm text-[var(--color-accent)] opacity-0 transition-opacity group-hover:opacity-100">查看案例 ↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 文章 ============ -->
    <section id="article" class="w-full py-20 md:py-28">
      <div class={wrap}>
        <h2 style="font-family:var(--font-display); font-size:clamp(48px,8vw,120px)" class="font-black tracking-tight">ARTICLE</h2>

        <div class="mt-12 grid gap-px overflow-hidden rounded-2xl border border-white/10 bg-white/10 sm:grid-cols-2">
          {articles.map((a, i) => (
            <a href={`/articles/${a.slug}`} class="group relative flex flex-col bg-[var(--color-ink)] p-8 transition-colors hover:bg-white/[0.04]">
              <span style="font-family:var(--font-display)" class="text-5xl font-black text-white/10 transition-colors group-hover:text-white/20">{String(i + 1).padStart(2, "0")}</span>
              <p class="mt-5 text-xl font-semibold leading-snug">{a.title}</p>
              <p class="mt-2 text-sm text-[var(--color-muted)]">{a.tag} · {a.read}</p>
              <p class="mt-3 line-clamp-3 text-[var(--color-muted)]">{a.excerpt}</p>
              <span class="mt-5 text-sm text-[var(--color-accent)] opacity-0 transition-opacity group-hover:opacity-100">阅读全文 ↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <footer class="w-full py-12 text-center text-sm text-[var(--color-muted)]/60">
      © 2026 吴悠 · UI/UX Portfolio
    </footer>
  </main>
</BaseLayout>
