---
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseImageGallery from '../components/CaseImageGallery.astro';

const images = Array.from(
  { length: 9 },
  (_, index) => `/assets/projects/mafengwo/${String(index + 1).padStart(2, "0")}.png`
);
---
<BaseLayout title="马蜂窝 · 营销活动设计 · 吴悠">
  <CaseImageGallery
    projectNo="PROJECT 02"
    title="马蜂窝 · 营销活动设计"
    subtitle="校企合作项目"
    tags={["创意视觉", "AIGC应用"]}
    images={images}
  />
</BaseLayout>
