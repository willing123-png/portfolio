---
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseImageGallery from '../components/CaseImageGallery.astro';

const images = Array.from(
  { length: 5 },
  (_, index) => `/assets/projects/exhibition/${String(index + 1).padStart(2, "0")}.png`
);
---

<BaseLayout title="看展助手 · AI 看展案例 · 吴悠" description="看展助手 —— 提升用户全流程的观展体验">
  <CaseImageGallery
    projectNo="PROJECT 04"
    title="AI 看展 · 0-1 项目"
    subtitle="抖音黑客松探索尝试"
    description="看展助手 —— 提升用户全流程的观展体验"
    tags={["设计创新"]}
    images={images}
  />
</BaseLayout>
