---
import { sceneLayers } from '../data/sceneLayers.js';
---

<section class="scene-shell" aria-label="2.5D motion scene">
  <div class="scene-stage" data-scene-stage>
    <div class="scene-background-track" aria-hidden="true">
      {Array.from({ length: 4 }).map(() => (
        <img class="scene-background-panel" src="/images/scene/scene-bg.png" alt="" />
      ))}
    </div>

    {sceneLayers.map((layer) => {
      const firstFrame = layer.keyframes[0];

      return (
        <img
          class={`scene-layer scene-layer-${layer.id}`}
          src={layer.src}
          alt={layer.alt}
          data-track-id={layer.id}
          style={`--x: ${firstFrame.x}; --y: ${firstFrame.y}; --w: ${firstFrame.width}; --opacity: ${firstFrame.opacity ?? 1}; --z: ${layer.z};`}
        />
      );
    })}
  </div>
</section>

<aside class="timeline-panel" data-timeline-panel aria-label="Timeline controls">
  <div class="timeline-panel-header">
    <strong>Timeline</strong>
    <button type="button" data-panel-reset>Reset</button>
  </div>

  <label class="timeline-control">
    <span>Playhead</span>
    <input data-playhead type="range" min="0" max="1" step="0.001" value="0" />
    <output data-playhead-value>0%</output>
  </label>

  <div class="timeline-row">
    <label class="timeline-control">
      <span>Track</span>
      <select data-track-select></select>
    </label>

    <label class="timeline-control">
      <span>Keyframe</span>
      <select data-keyframe-select></select>
    </label>
  </div>

  <label class="timeline-control">
    <span>X</span>
    <input data-param="x" type="range" min="-120" max="180" step="1" />
    <output data-param-value="x"></output>
  </label>

  <label class="timeline-control">
    <span>Y</span>
    <input data-param="y" type="range" min="-20" max="120" step="1" />
    <output data-param-value="y"></output>
  </label>

  <label class="timeline-control">
    <span>Size</span>
    <input data-param="width" type="range" min="2" max="180" step="1" />
    <output data-param-value="width"></output>
  </label>

  <label class="timeline-control">
    <span>Opacity</span>
    <input data-param="opacity" type="range" min="0" max="1" step="0.01" />
    <output data-param-value="opacity"></output>
  </label>

  <button class="timeline-copy" type="button" data-panel-copy>Copy current tracks</button>
  <textarea data-panel-output readonly spellcheck="false" aria-label="Current track data"></textarea>
</aside>
